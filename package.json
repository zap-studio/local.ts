    "test": "vp test",
    "test:coverage": "vp test run --coverage",
    "test:ui": "vp test run --ui",
    "test:watch": "vp test watch",
    "validate": "vp check && vp test && vp run build",
    "watch-routes": "vp exec tsr watch"
  },
